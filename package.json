{
  "name": "aeroc-admin-dashboard",
  "version": "1.0.0",
  "description": "Company Admin Dashboard",
  "type": "module",
  "main": "server/index.js",
  "scripts": {
    "start": "node server/index.js",
    "dev": "node server/index.js",
    "build:worker": "node scripts/build-worker.js",
    "deploy": "wrangler deploy",
    "db:schema": "wrangler d1 execute aeroc-admin-db --remote --file=./schemas/schema.sql"
  },
  "overrides": {
    "body-parser": "file:./stub"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "express": "^4.21.1",
    "jsonwebtoken": "^9.0.2"
  },
  "devDependencies": {
    "esbuild": "^0.27.4"
  }
}
